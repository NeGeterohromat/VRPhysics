      </group>
      <group targetFramework="UAP10.0.16299">
        <dependency id="System.Memory" version="4.5.3" />
      </group>
      <group targetFramework="Tizen4.0">
        <dependency id="System.Memory" version="4.5.3" />
      </group>
    </dependencies>
